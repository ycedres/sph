#!/usr/bin/env bb
;; -*- mode: clojure; fill-column: 88; clojure-docstring-fill-column: 88; -*-
(require '[babashka.fs :as fs]
         '[babashka.process :refer [sh shell]]
         '[babashka.http-client :as http]
         '[clojure.java.io :as io]
         '[clojure.string :as str])

;; Populate pkg/suse/ in an openSUSE/salt checkout automatically.
;; This program must be called from within the openSUSE/salt checkout

(defn- in-salt-checkout? []
  (-> (sh "git branch -l openSUSE/release/3006.0")
      :out
      (str/includes?  "openSUSE/release/3006.0")))

(defn- ensure-dir [d]
  (when-not (fs/exists? d)
    (println "Create directory" (str d))
    (fs/create-dirs d)))

(defn- git-repo-root []
  (:out (sh "git rev-parse")))

(defn- download [url dest]
  (println "Download" url "to" dest)
  (-> url
      (http/get {:as :stream})
      :body
      (io/copy (io/file dest))))

;; github.com
(def salt-packaging-files
  ["salt.spec", "salt-tmpfiles.d", "transactional_update.conf", "_multibuild",
   "update-documentation.sh", "README.SUSE", "html.tar.bz2"])

(defn- github-download-packaging-file [filename dest-dir]
  (let [url (str "https://raw.githubusercontent.com/openSUSE/salt-packaging/"
                 "refs/heads/release/3006.0/salt/" filename)
        dest (str (fs/path dest-dir filename))]
    (download url dest)))

